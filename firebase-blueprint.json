{
  "entities": {
    "UserKey": {
      "title": "UserKey",
      "description": "A user access key with monitoring and blocking capabilities.",
      "type": "object",
      "properties": {
        "key": { "type": "string", "description": "The key string." },
        "isBanned": { "type": "boolean", "description": "Whether the key is banned." },
        "expiresAt": { "type": "number", "description": "Expiration timestamp in milliseconds." },
        "blockedScreens": { "type": "array", "items": { "type": "string" }, "description": "List of blocked screen IDs." },
        "lastAction": { "type": "string", "description": "The last action taken by the user." },
        "lastActionAt": { "type": "number", "description": "Timestamp of the last action." },
        "currentScreen": { "type": "string", "description": "The screen the user is currently on." },
        "adminMessage": { "type": "string", "description": "A message sent by the admin to this user." }
      },
      "required": ["key", "isBanned"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "isBotOpen": { "type": "boolean", "description": "Whether the bot is open." },
        "botClosedMessage": { "type": "string", "description": "Message to show when the bot is closed." },
        "adminPassword": { "type": "string", "description": "Password for the admin panel." },
        "adminWhatsApp": { "type": "string", "description": "Admin WhatsApp number for activation requests." }
      },
      "required": ["isBotOpen", "botClosedMessage", "adminPassword", "adminWhatsApp"]
    },
    "ActivatedEmail": {
      "title": "ActivatedEmail",
      "description": "An email address that has been manually activated by an admin.",
      "type": "object",
      "properties": {
        "activatedAt": { "type": "number", "description": "Timestamp of activation." },
        "activatedBy": { "type": "string", "description": "Email of the admin who activated this account." }
      },
      "required": ["activatedAt"]
    }
  },
  "firestore": {
    "/userKeys/{keyId}": {
      "schema": "UserKey",
      "description": "Collection of user access keys."
    },
    "/appSettings/{settingId}": {
      "schema": "AppSetting",
      "description": "Collection of global application settings."
    },
    "/activated_emails/{email}": {
      "schema": "ActivatedEmail",
      "description": "Collection of manually activated email addresses."
    }
  }
}
