rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: userKeys
    // Document ID: keyId (the key string itself)
    // Fields:
    //   - key: string (required)
    //   - isBanned: boolean (required)
    //   - expiresAt: number (optional)
    //
    // Collection: appSettings
    // Document ID: settingId (e.g., 'global')
    // Fields:
    //   - isBotOpen: boolean (required)
    //   - botClosedMessage: string (required)
    //   - adminPassword: string (required)
    //   - adminWhatsApp: string (required)
    //
    // Collection: blocked_users
    // Document ID: email (the user's email)
    // Fields:
    //   - email: string (required)
    //   - reason: string (required)
    //   - blockedAt: number (required)
    //   - uid: string (optional)
    //
    // Collection: activated_emails
    // Document ID: email (the user's email)
    // Fields:
    //   - activatedAt: number (required)
    //   - activatedBy: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
        ((exists(userDoc) && get(userDoc).data.role == 'admin') ||
          (request.auth.token.email == "efronjoao9@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserKey(data) {
      return hasRequiredFields(['key', 'isBanned']) &&
             hasOnlyAllowedFields(['key', 'isBanned', 'expiresAt', 'blockedScreens', 'lastAction', 'lastActionAt', 'currentScreen', 'adminMessage']) &&
             data.key is string && data.key.size() >= 1 && data.key.size() <= 64 &&
             data.isBanned is bool &&
             (!('expiresAt' in data) || data.expiresAt == null || data.expiresAt is number) &&
             (!('blockedScreens' in data) || data.blockedScreens is list) &&
             (!('lastAction' in data) || data.lastAction is string) &&
             (!('lastActionAt' in data) || data.lastActionAt is number) &&
             (!('currentScreen' in data) || data.currentScreen is string) &&
             (!('adminMessage' in data) || data.adminMessage is string);
    }

    function isValidAppSetting(data) {
      return hasRequiredFields(['isBotOpen', 'botClosedMessage', 'adminPassword', 'adminWhatsApp']) &&
             hasOnlyAllowedFields(['isBotOpen', 'botClosedMessage', 'adminPassword', 'adminWhatsApp']) &&
             data.isBotOpen is bool &&
             data.botClosedMessage is string && data.botClosedMessage.size() <= 512 &&
             data.adminPassword is string && data.adminPassword.size() >= 1 && data.adminPassword.size() <= 128 &&
             data.adminWhatsApp is string && data.adminWhatsApp.size() >= 8 && data.adminWhatsApp.size() <= 20;
    }

    function isValidActivatedEmail(data) {
      return hasRequiredFields(['activatedAt']) &&
             hasOnlyAllowedFields(['activatedAt', 'activatedBy']) &&
             data.activatedAt is number &&
             (!('activatedBy' in data) || data.activatedBy is string);
    }

    function isValidBlockedUser(data) {
      return hasRequiredFields(['email', 'reason', 'blockedAt']) &&
             hasOnlyAllowedFields(['email', 'reason', 'blockedAt', 'uid']) &&
             data.email is string &&
             data.reason is string &&
             data.blockedAt is number;
    }

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'displayName']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'lastLogin']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             (!('role' in data) || data.role in ['user', 'admin']);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /userKeys/{keyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidUserKey(request.resource.data);
      allow update: if (isAdmin() && isValidUserKey(request.resource.data)) || 
                       (isAuthenticated() && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastAction', 'lastActionAt', 'currentScreen', 'adminMessage']));
      allow delete: if isAdmin();
    }

    match /test/{docId} {
      allow read: if true;
    }

    match /appSettings/{settingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidAppSetting(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated() && request.auth.uid == userId && 
                             isValidUser(request.resource.data) &&
                             (!request.resource.data.keys().hasAny(['role']) || isAdmin());
    }

    match /blocked_users/{email} {
      allow read: if isAuthenticated() && (request.auth.token.email == email || isAdmin());
      allow create: if isAuthenticated() && (request.auth.token.email == email || isAdmin()) && isValidBlockedUser(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /activated_emails/{email} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidActivatedEmail(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
